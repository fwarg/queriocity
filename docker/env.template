# Environment variables reference. Copy to env.local (Docker) or .env (local dev) and fill in values.
# For local dev, omit DB_PATH (defaults to ./queriocity.db).

# Server
# Generate with: openssl rand -base64 32
JWT_SECRET=
# CORS allowed origin. Defaults to * (open). Set to your domain in production.
# ALLOWED_ORIGIN=https://yourdomain.example

# Database — path inside container; mount a volume to /data
DB_PATH=/data/queriocity.db

# Unified base URL (e.g. litellm, ollama). If set, used as default for all providers unless overridden.
# BASE_PROVIDER defaults to 'openai'.
# BASE_URL=
# BASE_PROVIDER=openai

# Chat LLM
CHAT_PROVIDER=openai
CHAT_BASE_URL=
CHAT_MODEL=
# CHAT_API_KEY=sk-placeholder

# Thinking/reasoning LLM for researcher phase (falls back to chat if not set)
# THINKING_PROVIDER=openai
# THINKING_BASE_URL=
# THINKING_MODEL=
# THINKING_API_KEY=sk-placeholder

# Embedding LLM (falls back to chat server if not set)
EMBED_PROVIDER=openai
EMBED_BASE_URL=
EMBED_MODEL=
# EMBED_API_KEY=sk-placeholder
# Set embed_dimensions to the correct value for your embedding model
EMBED_DIMENSIONS=1024

# Small LLM for query reformulation (falls back to chat provider if not set)
SMALL_PROVIDER=openai
SMALL_BASE_URL=
SMALL_MODEL=
# SMALL_API_KEY=sk-placeholder

# Flash mode model override: 'small' uses SMALL_MODEL, otherwise uses CHAT_MODEL
# FLASH_MODEL=small

# Reranker — optional cross-encoder for result reranking (improves thorough mode and upload search)
# Set RERANK_MODEL to enable. RERANK_BASE_URL defaults to BASE_URL if omitted.
# RERANK_BASE_URL=
# RERANK_MODEL=

# SearXNG
SEARXNG_URL=

# Max chars of prior conversation passed to the reformulate model (keeps small-model context bounded). Requires ~4 chars/token.
# REFORMULATE_USER_CTX=400
# REFORMULATE_ASSISTANT_CTX=1000

# Context window size of your chat/thinking model in tokens. Used to trim conversation history before sending.
# Set to match your model (e.g. 32768 for 32k, 131072 for 128k). Defaults to 8192.
# CONTEXT_TOKEN_LIMIT=32768