# Server
PORT=3000
JWT_SECRET=change-me-in-production-32chars!!

# Database
DB_PATH=queriocity.db

# Chat LLM
CHAT_PROVIDER=ollama
CHAT_BASE_URL=http://localhost:11434/api
CHAT_MODEL=llama3.2
# CHAT_API_KEY=sk-placeholder

# Embedding LLM (falls back to chat server if not set)
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://localhost:11434/api
EMBED_MODEL=nomic-embed-text
# EMBED_API_KEY=sk-placeholder

# SearXNG
SEARXNG_URL=http://localhost:4000
