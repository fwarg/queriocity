{
  "name": "queriocity",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/server/index.ts",
    "dev:client": "vite dev --config vite.config.ts",
    "start": "bun run src/server/index.ts & vite dev --config vite.config.ts",
    "serve": "bun run src/server/index.ts",
    "build:client": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1",
    "@hono/zod-validator": "^0.2",
    "ai": "^4",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.30",
    "hono": "^4",
    "jose": "^5",
    "lucide-react": "^0.400.0",
    "ollama-ai-provider": "^1",
    "pdf-parse": "1",
    "pdfjs-dist": "^4",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1",
    "tesseract.js": "^5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pdf-parse": "1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "bun-types": "latest",
    "drizzle-kit": "^0.20",
    "eslint": "9",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5",
    "vite-plugin-pwa": "^1.2.0"
  },
  "trustedDependencies": [
    "es5-ext",
    "tesseract.js"
  ]
}
